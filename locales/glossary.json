  "descriptions": {
    "tagline": {
      "en": "AI Agent Security Platform for the Future",
      "de": "KI-Agenten-Sicherheitsplattform f\u00fcr die Zukunft",
      "es": "Plataforma de Seguridad de Agentes de IA para el Futuro",
      "fr": "Plateforme de S\u00e9curit\u00e9 des Agents IA pour l'Avenir",
      "it": "Piattaforma di Sicurezza Agenti IA per il Futuro",
      "pt": "Plataforma de Seguran\u00e7a de Agentes de IA para o Futuro",
      "nl": "AI Agent Beveiligingsplatform voor de Toekomst",
      "pl": "Platforma Bezpiecze\u0144stwa Agent\u00f3w AI na Przysz\u0142o\u015b\u0107",
      "ru": "\u041f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0430 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 AI-\u0430\u0433\u0435\u043d\u0442\u043e\u0432 \u0434\u043b\u044f \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043e",
      "tr": "Gelecek i\u00e7in AI Ajan G\u00fcvenlik Platformu",
      "ar": "\u0645\u0646\u0635\u0629 \u0623\u0645\u0627\u0646 \u0648\u0643\u0644\u0627\u0621 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u0644\u0645\u0633\u062a\u0642\u0628\u0644",
      "zh": "\u9762\u5411\u672a\u6765\u7684AI\u4ee3\u7406\u5b89\u5168\u5e73\u53f0",
      "ja": "\u672a\u6765\u5411\u3051AI\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u30bb\u30ad\u30e5\u30ea\u30c6\u30a3\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0",
      "ko": "\ubbf8\ub798\ub97c \uc704\ud55c AI \uc5d0\uc774\uc804\ud2b8 \ubcf4\uc548 \ud50c\ub7ab\ud3fc",
      "sv": "AI Agent S\u00e4kerhetsplattform f\u00f6r Framtiden"
    },
    "value_proposition": {
      "en": "Secure your AI agents with enterprise-grade protection in 30 seconds",
      "de": "Sichern Sie Ihre KI-Agenten mit Enterprise-Schutz in 30 Sekunden",
      "es": "Asegure sus agentes de IA con protecci\u00f3n de nivel empresarial en 30 segundos",
      "fr": "S\u00e9curisez vos agents IA avec une protection de niveau entreprise en 30 secondes",
      "it": "Proteggi i tuoi agenti IA con protezione enterprise in 30 secondi",
