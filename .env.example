# ──────────────────────────────────────────────────────────────
# ClawGuru – Environment Variables Example
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local or any file containing real secrets.
# ──────────────────────────────────────────────────────────────

# ── Auth / Tokens ──────────────────────────────────────────────
ACCESS_TOKEN_SECRET=
ADMIN_SESSION_SECRET=
MAGIC_LINK_SECRET=
NEXTAUTH_SECRET=

# ── Admin ──────────────────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=
ADMIN_IP=

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=
EMAIL_FROM=
EMAIL_REPLY_TO=
MAIL_FROM=
SUPPORT_EMAIL=
HEALTH_ALERT_EMAIL=
PASSIVE_SUMMARY_EMAIL=
TEST_EMAIL_RECIPIENT=

# ── Site ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
SITE_URL=

# ── Stripe ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_DAYPASS=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_INCIDENT=
STRIPE_PRICE_SPRINT=
STRIPE_PRICE_MSP=
NEXT_PUBLIC_PRODUCT_CHECKOUT_URL_INCIDENT=
NEXT_PUBLIC_PRODUCT_CHECKOUT_URL_SPRINT=
AFFILIATE_CONNECT_ACCOUNTS=
AFFILIATE_COMMISSION_RATE=
NEXT_PUBLIC_AFFILIATE_PROGRAM_URL=

# ── AI Providers ───────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=
GEMINI_TIMEOUT_MS=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

# ── Database / Redis ───────────────────────────────────────────
DATABASE_URL=
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Netlify ────────────────────────────────────────────────────
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
NETLIFY_ACCOUNT_ID=
NETLIFY_API_KEY=

# ── External APIs ──────────────────────────────────────────────
GITHUB_TOKEN=
GOOGLE_INDEXER_KEY=
NVD_API_KEY=
CVE_API_URL=
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
CLAWGURU_API_KEY=
INTEL_API_KEY=
INTEL_API_KEYS=
INTEL_API_URL=
DISCORD_WEBHOOK_URL=
SENTINEL_NOTIFY_URL=
ENTERPRISE_CONTACT_EMAIL=
ENTERPRISE_API_KEYS=

# ── Cron / Background Jobs ─────────────────────────────────────
CRON_SECRET=
BYPASS_SECRET=
ACCOUNTING_EXPORT_SECRET=
NEWSLETTER_UNSUBSCRIBE_SECRET=
MY_SECRET=

# ── Analytics ─────────────────────────────────────────────────
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=

# ── Feature Flags ──────────────────────────────────────────────
DISABLE_AI_FEATURES=
DISABLE_ALL_APIS=
MAINTENANCE_MODE=
AI_PROVIDER=

# ── Runtime Stats (optional, set by crons) ────────────────────
LAST_DAILY_INDEX_RUN=
GEMINI_TOKENS_INPUT_TODAY=
GEMINI_TOKENS_OUTPUT_TODAY=
GEMINI_TOKENS_7D_BURN=
GEMINI_TOKENS_MONTH_USED=
GEMINI_TOKENS_MONTH_LIMIT=
PSEO_RUNBOOK_COUNT=
RUNBOOK_EXECUTED_24H=
RUNBOOK_TREND_7D=
RUNBOOK_MYCELIUM_HEALTH=
LEGAL_AI_MAX_TOKENS=
