generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CveEntry {
  id               String   @id @default(cuid())
  cveId            String
  language         String
  slug             String
  title            String?
  createdAt        DateTime @default(now())

  @@index([cveId])
  @@index([language])
}

model AffiliateSale {
  id            String   @id @default(cuid())
  affiliateRef  String
  stripeSession String
  createdAt     DateTime @default(now())

  @@index([affiliateRef])
}

model LocalizedRunbook {
  id        String   @id @default(cuid())
  slug      String
  language  String
  title     String
  createdAt DateTime @default(now())

  @@index([language])
}
