# ============================================================
# ClawGuru – Environment Variables Reference
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Mark values as secret in Netlify/Vercel:
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, ADMIN_PASSWORD,
#   ADMIN_SESSION_SECRET, OPENAI_API_KEY, GEMINI_API_KEY,
#   RESEND_API_KEY, INTEL_API_KEYS
# ============================================================


# ------------------------------------------------------------
# Site
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://clawguru.org
# Fallback used server-side when NEXT_PUBLIC_SITE_URL is not available
SITE_URL=https://clawguru.org


# ------------------------------------------------------------
# Stripe (required for paid access)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
# Signing secret for Stripe webhook endpoint (/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...
# Signs the access cookie (httpOnly)
ACCESS_TOKEN_SECRET=replace-with-random-secret
# Signs magic-link tokens
MAGIC_LINK_SECRET=replace-with-another-random-secret

# Price IDs (hardcoded defaults in lib/stripe.ts – override here if needed)
STRIPE_PRICE_PRO=price_1SyY02INFtiy8u5xA9v6IeVA
STRIPE_PRICE_TEAM=price_1SyY1FINFtiy8u5xGhxFTkEe
STRIPE_PRICE_DAYPASS=price_1SyZiaINFtiy8u5xSuvtlste
# Optional additional price IDs
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_YEARLY=
# STRIPE_PRICE_SPRINT=
# STRIPE_PRICE_INCIDENT=
# STRIPE_PRICE_MSP=


# ------------------------------------------------------------
# Admin
# ------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@clawguru.org
# Signing secret for the admin session cookie
ADMIN_SESSION_SECRET=replace-with-random-secret
# Optional: secret to protect /api/admin/accounting-export
# ACCOUNTING_EXPORT_SECRET=


# ------------------------------------------------------------
# LLM / AI
# ------------------------------------------------------------
# Primary AI provider ("gemini" | "openai"). Defaults to "gemini".
AI_PROVIDER=gemini

# Google Gemini (primary)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_BASE_URL=
# GEMINI_TIMEOUT_MS=30000

# OpenAI (optional fallback)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=

# Set to "true" to disable all AI features (rule-based fallback only)
# DISABLE_AI_FEATURES=false
# Set to "true" to disable ALL external API calls (useful for maintenance)
# DISABLE_ALL_APIS=false


# ------------------------------------------------------------
# Intel Feed API
# ------------------------------------------------------------
# The Intel Feed (/api/intel/feeds) validates incoming requests with these keys.
# Status: currently returns curated static data (no external Intel server yet).
#
# - INTEL_API_KEYS: comma-separated list of valid API keys (preferred)
# - INTEL_API_KEY:  single API key (fallback if INTEL_API_KEYS is not set)
#
# If neither is set, every request to /api/intel/feeds returns HTTP 401.
#
INTEL_API_KEYS=key1,key2
# INTEL_API_KEY=single-key

# Optional: URL of an upstream Intel/threat intelligence API.
# Used by the health-check (checkIntelApi in lib/sentinel.ts) to verify
# the upstream feed is reachable.
# Falls back to CVE_API_URL, then the NIST NVD API if not set.
# There is currently no hosted intel.clawguru.org server – leave empty
# unless you operate your own feed endpoint.
# INTEL_API_URL=https://intel.clawguru.org/api/v1/health


# ------------------------------------------------------------
# Enterprise API (metered billing via Stripe)
# ------------------------------------------------------------
# Used by /api/v1/intel-feed/latest (and other enterprise endpoints).
# Format: key1:stripeCustomerId1:stripeSubItemId1,key2:...
# ENTERPRISE_API_KEYS=
# Stripe Price ID with usage_type=metered (for per-call billing)
# STRIPE_METERED_PRICE_ID=


# ------------------------------------------------------------
# Email (Resend)
# ------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM=ClawGuru <noreply@clawguru.org>
# EMAIL_FROM=ClawGuru <noreply@clawguru.org>
# EMAIL_REPLY_TO=support@clawguru.org
# SUPPORT_EMAIL=support@clawguru.org
# HEALTH_ALERT_EMAIL=ops@clawguru.org
# PASSIVE_SUMMARY_EMAIL=ops@clawguru.org
# NEWSLETTER_UNSUBSCRIBE_SECRET=


# ------------------------------------------------------------
# CVE / NVD
# ------------------------------------------------------------
# NVD API key (optional – raises rate limits from 5 to 50 req/30 s)
# NVD_API_KEY=
# Override the NVD CVE API URL (defaults to NIST NVD v2.0)
# CVE_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0


# ------------------------------------------------------------
# Discord notifications
# ------------------------------------------------------------
# DISCORD_WEBHOOK_URL=


# ------------------------------------------------------------
# Netlify (CI/CD & Edge API)
# ------------------------------------------------------------
# NETLIFY_AUTH_TOKEN=
# NETLIFY_SITE_ID=
# NETLIFY_ACCOUNT_ID=
# NETLIFY_API_KEY=


# ------------------------------------------------------------
# Sentinel / health monitoring
# ------------------------------------------------------------
# CRON_SECRET=             – shared secret for cron routes (/api/health/cron, /api/launch/cron)
# SENTINEL_NOTIFY_URL=     – optional webhook to POST health alerts to
# RUNBOOK_MYCELIUM_HEALTH=


# ------------------------------------------------------------
# Redis (optional – enables persistent caching / rate-limit store)
# ------------------------------------------------------------
# REDIS_URL=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=


# ------------------------------------------------------------
# GitHub / Google / misc integrations
# ------------------------------------------------------------
# GITHUB_TOKEN=            – used by google-indexer / sitemap submission
# GOOGLE_INDEXER_KEY=      – Google Indexing API service-account JSON (base64)
# HEYGEN_API_KEY=          – HeyGen video avatar generation
# HEYGEN_AVATAR_ID=
# HEYGEN_VOICE_ID=


# ------------------------------------------------------------
# Programmatic SEO / content
# ------------------------------------------------------------
# Number of auto-generated runbook pages (default: 1000)
# PSEO_RUNBOOK_COUNT=1000


# ------------------------------------------------------------
# Affiliate
# ------------------------------------------------------------
# AFFILIATE_CONNECT_ACCOUNTS=partnerId1:stripeAccountId1,...
# AFFILIATE_COMMISSION_RATE=0.3


# ------------------------------------------------------------
# Developer / testing
# ------------------------------------------------------------
# TEST_EMAIL_RECIPIENT=
# MY_SECRET=               – example placeholder used in some local scripts
# NEXTAUTH_SECRET=         – only needed if you re-enable NextAuth
# DATABASE_URL=            – only needed if you re-enable a database adapter
