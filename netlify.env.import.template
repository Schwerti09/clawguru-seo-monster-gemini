# ============================================================================
# Netlify Dashboard Environment Variables — SECRETS ONLY
# ============================================================================
# Since config/env-defaults.json provides non-secret defaults (inlined at
# build time and loaded at runtime via instrumentation.ts), you ONLY need
# to set actual secrets in the Netlify Dashboard.
#
# HOW TO CONFIGURE SCOPES IN NETLIFY DASHBOARD:
#   Site settings → Environment variables → Click a variable → Scopes
#   - "All deploys"   = available in Builds AND Functions (default)
#   - "Builds"        = available ONLY during builds, NOT in Functions
#   - "Functions"      = available ONLY in Functions
#   - "Post processing"= only during Netlify post-processing
#
# IMPORTANT: All vars with scope "All deploys" or "Functions" count toward
# the 4 KB function env limit.  Set build-only vars to "Builds" scope.
#
# BUDGET ESTIMATE:
#   [build.environment] in netlify.toml ≈ 70 bytes (NODE_VERSION + OMIT_PATHS)
#   Dashboard secrets below             ≈ 2–3 KB (depending on which you set)
#   TOTAL                               ≈ 2–3 KB   ← well under 4 KB ✓
#
# If you ever need SECRETS_SCAN_OMIT_KEYS, set it with scope "Builds" only.
# ============================================================================

# ── Required Secrets (scope: All deploys) ─────────────────────────────────────
# These are needed at both build time and runtime.

# Database / cache
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Auth / sessions
ACCESS_TOKEN_SECRET=CHANGE_ME_32PLUS_CHARS
NEXTAUTH_SECRET=CHANGE_ME_32PLUS_CHARS
SESSION_SECRET=CHANGE_ME_32PLUS_CHARS
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# AI providers (set at least one)
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── Optional Secrets (scope: All deploys — set only if using the feature) ─────

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_MSP=
STRIPE_PRICE_SPRINT=
STRIPE_PRICE_INCIDENT=
STRIPE_PRICE_DAYPASS=
STRIPE_METERED_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email
RESEND_API_KEY=

# Cron / admin
CRON_SECRET=
ADMIN_SESSION_SECRET=

# Geo secrets (set only if geo features are active)
GEO_EXPANSION_SECRET=
GEO_REVALIDATE_SECRET=
GEO_AUTO_PROMOTION_SECRET=
GEO_CANARY_ROLLOUT_SECRET=
GEO_SITEMAP_GUARDRAIL_SECRET=
GEO_ROLLOUT_STATUS_SECRET=
GEO_AUTO_PRUNE_SECRET=

# Integrations (set only if using the integration)
DISCORD_WEBHOOK_URL=
GITHUB_TOKEN=
GOOGLE_INDEXER_KEY=
INTEL_API_KEY=
NVD_API_KEY=
SENTINEL_NOTIFY_URL=
HEYGEN_API_KEY=
ENTERPRISE_API_KEYS=

# ── Build-Only Vars (scope: Builds — do NOT inject into Functions) ────────────
# Set these with scope "Builds" in the Netlify Dashboard if the secrets
# scanner still flags errors after SECRETS_SCAN_OMIT_PATHS covers .next/.
#
# SECRETS_SCAN_OMIT_KEYS=ACCESS_TOKEN_SECRET,ACCOUNTING_EXPORT_SECRET,ADMIN_API_TOKEN,...
# (full value documented in netlify.toml comments)
