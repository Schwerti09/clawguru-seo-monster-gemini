# =============================================================================
# ClawGuru – Environment Variables
# =============================================================================
# Kopiere diese Datei und fülle deine Werte ein:
#   cp .env.example .env.local
#
# Legende:
#   [REQUIRED]  – muss gesetzt sein, sonst startet die Funktion nicht
#   [OPTIONAL]  – hat einen Fallback-Wert oder ist ein Zusatz-Feature
# =============================================================================


# -----------------------------------------------------------------------------
# 1. SITE / DEPLOYMENT
# -----------------------------------------------------------------------------

# [REQUIRED] Öffentliche URL der App (z. B. https://clawguru.org)
NEXT_PUBLIC_SITE_URL=https://clawguru.org

# [OPTIONAL] Interne Server-seitige URL (Fallback auf NEXT_PUBLIC_SITE_URL)
SITE_URL=https://clawguru.org


# -----------------------------------------------------------------------------
# 2. STRIPE – Zahlungsabwicklung
# -----------------------------------------------------------------------------

# [REQUIRED] Stripe Secret Key (sk_live_... für Produktion, sk_test_... für Tests)
STRIPE_SECRET_KEY=sk_live_...

# [REQUIRED] HMAC-Secret zum Signieren des Access-Cookies
ACCESS_TOKEN_SECRET=ein-langes-zufaelliges-geheimnis

# [OPTIONAL] Stripe Webhook Signing Secret (empfohlen für sichere Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# [OPTIONAL] Stripe Price IDs – nur nötig wenn du die eingebauten IDs überschreiben willst
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_DAYPASS=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_SPRINT=price_...
STRIPE_PRICE_INCIDENT=price_...
STRIPE_PRICE_MSP=price_...

# [OPTIONAL] Usage-based Billing (Metered)
# STRIPE_METERED_PRICE_ID=price_...

# [OPTIONAL] Direkte Checkout-URLs für Sprint / Incident-Kit
NEXT_PUBLIC_PRODUCT_CHECKOUT_URL_SPRINT=https://buy.stripe.com/...
NEXT_PUBLIC_PRODUCT_CHECKOUT_URL_INCIDENT=https://buy.stripe.com/...


# -----------------------------------------------------------------------------
# 3. KI / LLM – AI-Provider
# -----------------------------------------------------------------------------

# [OPTIONAL] AI-Provider: "gemini" oder "openai" (Default: openai)
AI_PROVIDER=gemini

# Google Gemini
# [OPTIONAL] Wenn gesetzt, antwortet der Copilot mit Gemini (sonst rule-based)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_TIMEOUT_MS=60000

# OpenAI (Fallback oder primär wenn AI_PROVIDER=openai)
# [OPTIONAL] OpenAI API Key
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# [OPTIONAL] Max Tokens für den Legal-AI-Endpoint
LEGAL_AI_MAX_TOKENS=2000


# -----------------------------------------------------------------------------
# 4. E-MAIL – Resend
# -----------------------------------------------------------------------------

# [OPTIONAL] Resend API Key für transaktionale E-Mails
RESEND_API_KEY=re_...

# [OPTIONAL] Absender-Adresse (muss in Resend verifiziert sein)
RESEND_FROM=ClawGuru <noreply@clawguru.org>
EMAIL_FROM=ClawGuru <noreply@clawguru.org>
MAIL_FROM=ClawGuru <noreply@clawguru.org>

# [OPTIONAL] Reply-To und Support-Adresse
EMAIL_REPLY_TO=support@clawguru.org
SUPPORT_EMAIL=support@clawguru.org

# [OPTIONAL] Admin-E-Mail (Fallback: admin@clawguru.org)
ADMIN_EMAIL=admin@clawguru.org

# [OPTIONAL] Zieladresse für Test-E-Mails
TEST_EMAIL_RECIPIENT=test@clawguru.org

# [OPTIONAL] Zieladresse für Health-Alerts per E-Mail
HEALTH_ALERT_EMAIL=alert@clawguru.org

# [OPTIONAL] Zieladresse für den passiven Health-Bericht
PASSIVE_SUMMARY_EMAIL=rolf@clawguru.org


# -----------------------------------------------------------------------------
# 5. DISCORD – Benachrichtigungen
# -----------------------------------------------------------------------------

# [OPTIONAL] Discord Webhook URL für interne Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...


# -----------------------------------------------------------------------------
# 6. ADMIN-BEREICH
# -----------------------------------------------------------------------------

# [OPTIONAL] Admin-Login (alle drei müssen gesetzt sein, damit der Login aktiv ist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ein-starkes-passwort
ADMIN_SESSION_SECRET=ein-langes-zufaelliges-geheimnis

# [OPTIONAL] NextAuth Secret (Fallback für Token-Signierung)
NEXTAUTH_SECRET=ein-langes-zufaelliges-geheimnis

# [OPTIONAL] Admin IP-Adresse zum automatischen Bypass des Maintenance-Modus
ADMIN_IP=1.2.3.4

# [OPTIONAL] Secret zum Schutz des Accounting-Exports
ACCOUNTING_EXPORT_SECRET=geheimnis-fuer-accounting-export


# -----------------------------------------------------------------------------
# 7. AUTHENTICATION / MAGIC LINK
# -----------------------------------------------------------------------------

# [OPTIONAL] Secret zum Signieren von Magic-Link-Tokens
MAGIC_LINK_SECRET=ein-langes-zufaelliges-geheimnis

# [OPTIONAL] Secret für Newsletter-Unsubscribe-Links
NEWSLETTER_UNSUBSCRIBE_SECRET=ein-langes-zufaelliges-geheimnis


# -----------------------------------------------------------------------------
# 8. CRON JOBS
# -----------------------------------------------------------------------------

# [OPTIONAL] Bearer-Secret zum Schutz von Cron-Endpunkten
CRON_SECRET=ein-langes-zufaelliges-geheimnis


# -----------------------------------------------------------------------------
# 9. GOOGLE INDEXING API
# -----------------------------------------------------------------------------

# [OPTIONAL] Google Indexing API – Service Account JSON (als String, Base64 oder Pfad)
GOOGLE_INDEXER_KEY={"type":"service_account","project_id":"..."}


# -----------------------------------------------------------------------------
# 10. NVD / CVE – Vulnerability-Daten
# -----------------------------------------------------------------------------

# [OPTIONAL] NIST NVD API Key (erhöht Rate-Limit)
NVD_API_KEY=...

# [OPTIONAL] Custom CVE API URL (Fallback auf öffentliche NVD API)
CVE_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0


# -----------------------------------------------------------------------------
# 11. INTEL API (internes API-Gateway)
# -----------------------------------------------------------------------------

# [OPTIONAL] Einzelner Intel API Key
INTEL_API_KEY=...

# [OPTIONAL] Mehrere Keys, kommagetrennt
INTEL_API_KEYS=key1,key2,key3

# [OPTIONAL] Eigener Intel API Endpunkt
INTEL_API_URL=https://api.intel.clawguru.org

# [OPTIONAL] Eigener ClawGuru API Key (für interne Dienste)
CLAWGURU_API_KEY=...


# -----------------------------------------------------------------------------
# 12. ENTERPRISE API
# -----------------------------------------------------------------------------

# [OPTIONAL] Enterprise API Keys (Format: key:customerId:subscriptionItemId, kommagetrennt)
ENTERPRISE_API_KEYS=key1:cus_xxx:si_xxx,key2:cus_yyy:si_yyy

# [OPTIONAL] Kontakt-E-Mail für Enterprise-Anfragen
ENTERPRISE_CONTACT_EMAIL=enterprise@clawguru.org


# -----------------------------------------------------------------------------
# 13. AFFILIATE / PARTNER-PROGRAMM
# -----------------------------------------------------------------------------

# [OPTIONAL] Secret für Affiliate-Authentifizierung
AFFILIATE_SECRET=geheimnis-fuer-affiliate

# [OPTIONAL] Stripe Connect Accounts JSON (ref → accountId)
AFFILIATE_CONNECT_ACCOUNTS={"partner1":"acct_xxx"}

# [OPTIONAL] Provision-Rate (0.40 = 40 %)
AFFILIATE_COMMISSION_RATE=0.40

# [OPTIONAL] URL zum Partner-Dashboard
NEXT_PUBLIC_AFFILIATE_PROGRAM_URL=https://affiliate.clawguru.org


# -----------------------------------------------------------------------------
# 14. NETLIFY – Deployment & Management API
# -----------------------------------------------------------------------------

# [REQUIRED für GitHub Actions Deploy] Netlify Personal Access Token
NETLIFY_AUTH_TOKEN=...

# [REQUIRED für GitHub Actions Deploy] Netlify Site ID
NETLIFY_SITE_ID=...

# [OPTIONAL] Netlify API Key (alternativ zu AUTH_TOKEN)
NETLIFY_API_KEY=...

# [OPTIONAL] Netlify Account / Team ID
NETLIFY_ACCOUNT_ID=...


# -----------------------------------------------------------------------------
# 15. GITHUB
# -----------------------------------------------------------------------------

# [OPTIONAL] GitHub Personal Access Token (für Merge-Request-Feature etc.)
GITHUB_TOKEN=ghp_...


# -----------------------------------------------------------------------------
# 16. HEYGEN – Video-Agent
# -----------------------------------------------------------------------------

# [OPTIONAL] HeyGen API Key für KI-Video-Generierung
HEYGEN_API_KEY=...

# [OPTIONAL] Avatar- und Voice-ID (haben eingebaute Defaults)
HEYGEN_AVATAR_ID=Wayne_20240711
HEYGEN_VOICE_ID=1bd001e7e50f421d891986aad5158bc8


# -----------------------------------------------------------------------------
# 17. REDIS / DATENBANK
# -----------------------------------------------------------------------------

# [OPTIONAL] Standard Redis Connection URL
REDIS_URL=redis://localhost:6379

# [OPTIONAL] Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# [OPTIONAL] Primäre Datenbank-URL (Postgres / PlanetScale etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname


# -----------------------------------------------------------------------------
# 18. ANALYTICS – Umami
# -----------------------------------------------------------------------------

# [OPTIONAL] Umami Website ID (Privacy-freundliche Analytics)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=...

# [OPTIONAL] Umami Script URL
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://umami.is/script.js


# -----------------------------------------------------------------------------
# 19. MONITORING – Sentinel
# -----------------------------------------------------------------------------

# [OPTIONAL] Webhook URL für Health-Check-Alerts (Slack / Discord / Telegram)
SENTINEL_NOTIFY_URL=https://...


# -----------------------------------------------------------------------------
# 20. MAINTENANCE / FEATURE-FLAGS
# -----------------------------------------------------------------------------

# [OPTIONAL] Wartungsmodus aktivieren (true/false)
MAINTENANCE_MODE=false

# [OPTIONAL] Secret zum Bypass des Wartungsmodus
BYPASS_SECRET=geheimnis-fuer-bypass

# [OPTIONAL] Alle externen API-Calls deaktivieren (true/false)
DISABLE_ALL_APIS=false

# [OPTIONAL] Nur AI-Endpoints deaktivieren (true/false)
DISABLE_AI_FEATURES=false


# -----------------------------------------------------------------------------
# 21. PSEO / CONTENT
# -----------------------------------------------------------------------------

# [OPTIONAL] Anzahl der generierten Runbooks (Default: 500)
PSEO_RUNBOOK_COUNT=500

# [OPTIONAL] Dashboard-Statistiken (werden im Admin-Cockpit angezeigt)
RUNBOOK_TREND_7D=12,18,15,22,20,25,28
RUNBOOK_MYCELIUM_HEALTH=98.7
LAST_DAILY_INDEX_RUN=2026-01-01T00:00:00Z


# -----------------------------------------------------------------------------
# 22. NODE
# -----------------------------------------------------------------------------

# Automatisch von Next.js/Netlify gesetzt – in der Regel nicht manuell nötig
# NODE_ENV=production
