# Netlify production env import template
# Copy to a local file (e.g. netlify.env.production) and replace placeholders.

# Core site
NEXT_PUBLIC_SITE_URL=https://clawguru.org
SITE_URL=https://clawguru.org

# Database / cache
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
REDIS_URL=redis://default:password@host:port
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Auth / admin
ACCESS_TOKEN_SECRET=CHANGE_ME_32PLUS_CHARS
NEXTAUTH_SECRET=CHANGE_ME_32PLUS_CHARS
SESSION_SECRET=CHANGE_ME_32PLUS_CHARS
ADMIN_SESSION_SECRET=CHANGE_ME_32PLUS_CHARS
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# AI providers
AI_PROVIDER_ORDER=deepseek,gemini,openai
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MAX_OUTPUT_TOKENS=2048
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Email / support
RESEND_API_KEY=
RESEND_FROM=noreply@clawguru.org
EMAIL_FROM=ClawGuru <noreply@clawguru.org>
