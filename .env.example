# ─────────────────────────────────────────────────────────────────────────────
# ClawGuru SEO Monster – Environment Variables Reference
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://clawguru.org
SITE_URL=https://clawguru.org

# ── Enterprise API Authentication ─────────────────────────────────────────────
# Comma-separated list of enterprise API key entries.
# Each entry has the format:  <api_key>:<stripe_customer_id>:<stripe_subscription_item_id>
# Example (multiple keys):
#   ENTERPRISE_API_KEYS=ek_live_abc123:cus_AABBCC:si_XXYYZZ,ek_live_def456:cus_DDEEFF:si_AABBCC
# Leave empty to disable enterprise API access.
ENTERPRISE_API_KEYS=

# Enterprise contact / notification e-mail.
# Incoming enterprise contact form submissions are sent to this address.
# Fallback: support@clawguru.org
ENTERPRISE_CONTACT_EMAIL=support@clawguru.org

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_METERED_PRICE_ID=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM=
# STRIPE_PRICE_ENTERPRISE: Enterprise API checkout price ID.
# If not set, STRIPE_PRICE_TEAM is used as a fallback.
# NOTE: The correct name is STRIPE_PRICE_TEAM (not STRIPE_PRISE_TEAM).
#       STRIPE_PRISE_TEAM is accepted as a legacy alias for backwards compatibility.
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_MSP=
STRIPE_PRICE_SPRINT=
STRIPE_PRICE_INCIDENT=
STRIPE_PRICE_DAYPASS=

# ── Email / Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@clawguru.org
EMAIL_FROM=ClawGuru <noreply@clawguru.org>
EMAIL_REPLY_TO=support@clawguru.org
SUPPORT_EMAIL=support@clawguru.org
ADMIN_EMAIL=admin@clawguru.org
HEALTH_ALERT_EMAIL=alerts@clawguru.org
PASSIVE_SUMMARY_EMAIL=summary@clawguru.org
TEST_EMAIL_RECIPIENT=test@example.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Redis / Upstash ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Auth / Sessions ───────────────────────────────────────────────────────────
# ACCESS_TOKEN_SECRET is required for magic link (email login) to work.
# Used to sign and verify access tokens sent via email. Must be the same value
# across all instances (e.g. Netlify deploys). A random 32+ character string.
# Falls back to NEXTAUTH_SECRET, then SESSION_SECRET if not set.
ACCESS_TOKEN_SECRET=
NEXTAUTH_SECRET=
MAGIC_LINK_SECRET=

# SESSION_SECRET is used to sign user session cookies.
# Falls back to ADMIN_SESSION_SECRET, then derives from ACCESS_TOKEN_SECRET
# (via HMAC) if neither is set – set SESSION_SECRET explicitly in production.
SESSION_SECRET=
ADMIN_SESSION_SECRET=

# Admin login credentials.
# ADMIN_USERNAME=your-admin-username
# explicitly in production (CONTEXT=production). ADMIN_PASSWORD is always required.
# Accepted aliases: ADMIN_USER_NAME (username), ADMIN_PASSWORT (password).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── AI Providers ──────────────────────────────────────────────────────────────
# Comma-separated provider priority. DeepSeek is first because it is cheapest
# and avoids Gemini 429 quota errors when GEMINI_API_KEY is not configured.
# Providers whose API key is absent are skipped automatically.
AI_PREFERRED=deepseek,openai,gemini
AI_PROVIDER=deepseek
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_TIMEOUT_MS=30000

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com

# ── Netlify ───────────────────────────────────────────────────────────────────
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
NETLIFY_ACCOUNT_ID=
NETLIFY_API_KEY=

# ── Integrations ──────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
GITHUB_TOKEN=
GOOGLE_INDEXER_KEY=
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
INTEL_API_KEY=
# INTEL_API_KEYS accepts a comma-separated list of keys (multi-key rotation support)
INTEL_API_KEYS=
INTEL_API_URL=
NVD_API_KEY=
CVE_API_URL=
SENTINEL_NOTIFY_URL=

# ── Miscellaneous ─────────────────────────────────────────────────────────────
CRON_SECRET=
ACCOUNTING_EXPORT_SECRET=
NEWSLETTER_UNSUBSCRIBE_SECRET=
AFFILIATE_COMMISSION_RATE=0.30
MAINTENANCE_MODE=false
DISABLE_AI_FEATURES=false
DISABLE_ALL_APIS=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=