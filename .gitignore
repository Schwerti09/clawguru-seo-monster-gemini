# dependencies
node_modules/
**/node_modules/**

# next build
.next/
**/.next/**
out/

# cloudflare workers build output
.worker-next/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/*.log

# i18n pipeline B — generated artifacts. Both paths are deterministic outputs
# of scripts/i18n-harvest-pick-sources.js / i18n-build-autotranslate*.js and
# regenerate from app/+components/ source on every run. Committing them creates
# 800k+ JSON diffs on every page edit and frequent merge conflicts.
# Only the consolidated lib/i18n-autotranslate.ts is a stable artifact.
lib/i18n-pick-sources.json
lib/i18n-autotranslate/*.json

# env files (NEVER commit real secrets)
.env
.env.local
**/.env.local
.env.development
.env.production
.env.*
# prevent committing exported/backup env files
env-*.env
env-*.production
# Platform-specific runtime env files with real secrets
netlify.env.production
netlify.env.import
netlify.env.clean

# common backup artifacts
*.bak
*.bakcmd

# Shell artifacts

# mac / windows junk
.DS_Store
Thumbs.db

# build artifacts
dist/
**/dist/**
build/
**/build/**

# netlify
# Trailing slash ensures the entire directory (including state files) is ignored.
# NOTE: Already-tracked .netlify/ files must be removed manually:
#   git rm -r --cached .netlify/ && git commit -m "chore: untrack .netlify state files" && git push
.netlify/

# vscode
.vscode
.vercel
**/.vercel/**
.env*.local

# deployment: exclude large local artifacts to keep upload small
tmp/
_deploy/
downloads-src/
.cache/
.turbo/
.husky/
.pnpm-store/
.nyc_output/
coverage/
.next-tmp/
.vercel-output/
.lh-*/
.lighthouse*/
lhtmp*/
.lhtmp*/
.lhtmp-*/
.lhtmp2-*/
.lhtmp3-*/
.lhtmp4-*/
lh-*.json
clawguru-seo-monster-gemini-*/
.git/
# large local bundles/archives — never commit (except public/downloads/ assets)
**/*.zip
!public/downloads/*.zip

 
# large local bundles/archives � never commit
*.tgz
*.tar.gz
*.tar
clawguru-deploy.tgz
tsconfig.tsbuildinfo

# Playwright
test-results/
playwright-report/
.playwright-cache/

# Local deployment artifacts
DEPLOY_ID.txt
deno.lock
test-gemini.js
fix-broken.js
enrichment-test.log
