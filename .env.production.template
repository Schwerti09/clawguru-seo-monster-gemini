# AI Provider Configuration (für On-Demand Content Generation)
# Reihenfolge: deepseek,openai,gemini (DeepSeek zuerst wegen Rate-Limits)
AI_PREFERRED=deepseek,openai,gemini
AI_PROVIDER=deepseek

# API Keys (müssen in Vercel gesetzt sein)
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Sitemap Configuration (für 400k+ indexierbare Seiten)
SITEMAP_ALLOW_CHUNK=1
SITEMAP_BUCKETS=5
SITEMAP_RUNBOOKS_PER_BUCKET=2000
SITEMAP_100K_LOCALES=de,en

# PSEO Runbook Generation (kuratierte Premium-Runbooks)
PSEO_RUNBOOK_COUNT=1200

# Optional: Strict Quality Mode für 100k-Sitemaps
# SITEMAP_QUALITY_STRICT=1

# Database (falls vorhanden)
# DATABASE_URL=postgresql://...

# Auth Secrets (falls vorhanden)
# NEXTAUTH_SECRET=...
# ACCESS_TOKEN_SECRET=...
# SESSION_SECRET=...

# Google Services (falls vorhanden)
# GOOGLE_APPLICATION_CREDENTIALS=...
# GOOGLE_INDEXER_KEY=...

# Stripe (falls vorhanden)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
