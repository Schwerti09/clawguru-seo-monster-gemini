# AI Provider Configuration
# Non-secret defaults are now in config/env-defaults.json (inlined at build time).
# Only set these to OVERRIDE the defaults:
#   AI_PROVIDER_ORDER=gemini,openai,deepseek  (default)
#   GEMINI_MODEL=gemini-2.5-flash             (default)

# API Keys (müssen in Vercel/Netlify gesetzt sein)
# DEEPSEEK_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENAI_API_KEY=sk-...

# Sitemap Configuration — QUALITY OVER QUANTITY
# Only de,en locales in sitemap (content pages are not translated for other locales)
SITEMAP_ALLOW_CHUNK=1
SITEMAP_BUCKETS=5
SITEMAP_RUNBOOKS_PER_BUCKET=2000
SITEMAP_100K_LOCALES=de,en
SITEMAP_QUALITY_STRICT=1
SITEMAP_INCLUDE_SYNTHETIC_100K=0

# PSEO Runbook Generation (kuratierte Premium-Runbooks)
PSEO_RUNBOOK_COUNT=1200

# Database (falls vorhanden)
# DATABASE_URL=postgresql://...

# Auth Secrets (falls vorhanden)
# NEXTAUTH_SECRET=...
# ACCESS_TOKEN_SECRET=...
# SESSION_SECRET=...

# Google Services (falls vorhanden)
# GOOGLE_APPLICATION_CREDENTIALS=...
# GOOGLE_INDEXER_KEY=...

# Stripe (falls vorhanden)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
